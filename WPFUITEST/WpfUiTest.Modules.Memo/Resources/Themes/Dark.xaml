<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 自定义暗黑主题颜色 -->

    <!-- ====================备忘录数据区域Border渐变颜色 ==================== -->
    <!-- 备忘录 - 暗黑主题（暖棕琥珀，暗黑高对比，避开青/紫色系） -->
    <LinearGradientBrush x:Key="MemoDataGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <!--
        <GradientStop Color="#1E293B" Offset="0.0"/>
        <GradientStop Color="#3F2F26" Offset="0.4"/>
        <GradientStop Color="#78350F" Offset="0.7"/>
        <GradientStop Color="#B45309" Offset="1.0"/>
        -->
        <!-- 统一深基底（和你的卡片一致） -->
        <!-- 深棕过渡 -->
        <!-- 焦糖棕过渡 -->
        <!-- 右下角暖琥珀（醒目不刺眼） -->

        <GradientStop Color="#27272A" Offset="0.0"/>
        <!-- 左上角深灰紫底 -->
        <GradientStop Color="#4C1D95" Offset="0.4"/>
        <!-- 中间暗紫蓝（主色#7C3AED深化） -->
        <GradientStop Color="#6D28D9" Offset="0.7"/>
        <!-- 中后段深紫蓝（接近主色） -->
        <GradientStop Color="#7C3AED" Offset="1.0"/>
        <!-- 右下角亮紫蓝（核心主色） -->
    </LinearGradientBrush>

    <!-- 深色 - 备忘录边缘效果（紫蓝高亮霓虹） -->
    <DropShadowEffect x:Key="MemoDataDropShadowEffect"
                      ShadowDepth="0"
                      BlurRadius="18"
                      Color="#C084FC"
                      Opacity="0.9"/>
</ResourceDictionary>