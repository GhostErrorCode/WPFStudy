<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 自定义明亮主题颜色 -->

    <!-- ==================== 备忘录数据区域Border渐变颜色 ==================== -->
    <!-- 备忘录 - 浅色主题（暖杏奶咖，柔和护眼，与青紫完全区分） -->
    <LinearGradientBrush x:Key="MemoDataGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFDFB" Offset="0.0"/>
        <!-- 左上角奶白基底 -->
        <GradientStop Color="#FFFAF0" Offset="0.4"/>
        <!-- 暖杏色过渡 -->
        <GradientStop Color="#FEEBC8" Offset="0.7"/>
        <!-- 浅咖色过渡 -->
        <GradientStop Color="#FCD34D" Offset="1.0"/>
        <!-- 右下角柔琥珀色 -->
    </LinearGradientBrush>
</ResourceDictionary>