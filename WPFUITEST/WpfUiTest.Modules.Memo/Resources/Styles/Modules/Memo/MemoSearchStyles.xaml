<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <!-- 先把Icon控件单独拿出来，这里有个大坑，Icon只有一个实例，导致第一个控件设置后，第二个控件再设置就会把第一个控件的实例抢走，导致第一个控件的Icon就没了 -->
    <!-- 共享实例设置为False -->
    <!-- 输入框Icon -->
    <ui:SymbolIcon x:Key="IconSearch24" Symbol="Search24" x:Shared="False"/>
    <ui:SymbolIcon x:Key="IconArrowClockwise24" Symbol="ArrowClockwise24" x:Shared="False"/>
    <ui:SymbolIcon x:Key="IconAdd24" Symbol="Add24" x:Shared="False"/>

    <!-- 搜索标签TextBlock样式 -->
    <Style x:Key="MemoSearchFieldLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- 搜索文本框TextBox样式 -->
    <Style x:Key="MemoSearchTextBoxStyle" TargetType="{x:Type ui:TextBox}" BasedOn="{StaticResource {x:Type ui:TextBox}}">
        <Setter Property="IconPlacement" Value="Right" />
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="0,5,20,5"/>
        <Setter Property="Width" Value="220" />
        <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <!-- 搜索按钮UiButton样式 -->
    <Style x:Key="MemoSearchUiButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <!-- 按钮外观为主要 -->
        <Setter Property="Appearance" Value="Primary" />
        <Setter Property="Height" Value="35" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Margin" Value="5,5,15,5" />
        <Setter Property="Icon" Value="{StaticResource IconSearch24}" />
    </Style>

    <!-- 搜索重置按钮UiButton样式 -->
    <Style x:Key="MemoSearchResetUiButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <!-- 按钮外观为次要 -->
        <Setter Property="Appearance" Value="Secondary" />
        <Setter Property="Height" Value="35" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Margin" Value="5,5,12,5" />
        <Setter Property="Icon" Value="{StaticResource IconArrowClockwise24}" />
    </Style>

    <!-- 添加备忘录按钮样式 -->
    <Style x:Key="AddMemoUiButtonStyle" TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
        <!-- 按钮外观为次要 -->
        <Setter Property="Appearance" Value="Primary" />
        <Setter Property="Height" Value="35" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Margin" Value="12,5,15,5" />
        <Setter Property="Icon" Value="{StaticResource IconAdd24}" />
    </Style>
</ResourceDictionary>