<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <!-- 先把Icon控件单独拿出来，这里有个大坑，Icon只有一个实例，导致第一个控件设置后，第二个控件再设置就会把第一个控件的实例抢走，导致第一个控件的Icon就没了 -->
    <!-- 共享实例设置为False -->
    <!-- 密码框Icon -->
    <ui:SymbolIcon x:Key="IconPassword24" Symbol="Password24" x:Shared="False"/>

    <!-- 注册登录密码输入框样式 ui:Password -->
    <Style
        x:Key="UiPasswordBoxStyle"
        TargetType="{x:Type ui:PasswordBox}"
        BasedOn="{StaticResource {x:Type ui:PasswordBox}}">
        <!-- 长宽与外边距 -->
        <!-- 不设置宽度，控件会自适应父容器的 -->
        <Setter Property="Height" Value="35"/>
        <Setter Property="Margin" Value="5,5,5,5"/>
        <!-- 输入文本框的图标 -->
        <Setter Property="Icon" Value="{StaticResource IconPassword24}" />
    </Style>
</ResourceDictionary>