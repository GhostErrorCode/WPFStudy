<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    xmlns:enums="clr-namespace:WpfUiTest.App.ViewModels.Enums"
                    >
    <!-- 首页汇总Border样式 -->
    <Style
        x:Key="IndexSummaryBorderStyle"
        TargetType="{x:Type Border}"
        >
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="CornerRadius" Value="10,10,10,10" />
        <!-- 裁剪超出区域 -->
        <Setter Property="ClipToBounds" Value="True" />
        
        <!-- 渐变背景色 -->
        <Style.Triggers>
            <!-- <DataTrigger Binding="{Binding SummaryType}" Value="ToDoTotal">不需要匹配枚举类，直接匹配枚举字符串即可（隐式转换） -->
            <!-- 显示声明 -->
            <DataTrigger Binding="{Binding SummaryType}" Value="{x:Static enums:IndexSummaryType.ToDoTotal}">
                <Setter Property="Background" Value="{DynamicResource IndexSummaryToDoTotalGradientBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SummaryType}" Value="{x:Static enums:IndexSummaryType.ToDoCompleted}">
                <Setter Property="Background" Value="{DynamicResource IndexSummaryTodoCompletedGradientBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SummaryType}" Value="{x:Static enums:IndexSummaryType.ToDoCompletionRate}">
                <Setter Property="Background" Value="{DynamicResource IndexSummaryTodoCompletionRateGradientBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SummaryType}" Value="{x:Static enums:IndexSummaryType.MemoTotal}">
                <Setter Property="Background" Value="{DynamicResource IndexSummaryMemoTotalGradientBrush}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding SummaryType}" Value="{x:Static enums:IndexSummaryType.Custom}">
                <Setter Property="Background" Value="{DynamicResource IndexSummaryToDoTotalGradientBrush}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 首页汇总Icon样式 -->
    <Style
        x:Key="IndexSummaryIconStyle"
        TargetType="{x:Type ui:SymbolIcon}"
        >
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Filled" Value="False" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- 首页汇总TextBlock样式(ui:TextBlock样式用不了，不知道为什么) -->
    <Style
        x:Key="IndexSummaryTextBlockStyle"
        TargetType="{x:Type TextBlock}"
        BasedOn="{StaticResource TitleThreeUiTextBlockStyle}"
        >
        <Setter Property="Margin" Value="4,4,0,4" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
</ResourceDictionary>