<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:WpfUiTest.App.Resources.Converters">
    <!-- 转换器资源字典 -->
    
    <!-- 设置页面 应用主题 转 字符串 -->
    <converters:ThemeToStringConverter x:Key="ThemeToStringConverter" />
    
    <!-- 首页 汇总ItemsControl数量 转 列数 -->
    <converters:ItemsCountToColumnsConverter x:Key="ItemsCountToColumnsConverter" />
    
    <!-- 首页 待办事项状态 转 ComboBox要显示的字符 -->
    <converters:ToDoStatusToStringConverter x:Key="ToDoStatusToStringConverter" />
</ResourceDictionary>