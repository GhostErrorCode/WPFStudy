<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 自定义高对比度主题颜色 -->

    <!-- 白色文本 -->
    <SolidColorBrush x:Key="TextFillColorWhiteBrush" Color="#FFFFFF"/>

    <!-- ==================== 首页汇总区域Boder渐变颜色 ==================== -->
    <!-- 1. ToDoTotal（汇总）- 高对比蓝（不刺眼版） -->
    <LinearGradientBrush x:Key="IndexSummaryToDoTotalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <!-- 高对比基础白 -->
        <GradientStop Color="#0050CC" Offset="1"/>
        <!-- 高对比蓝，低饱和不刺眼 -->
    </LinearGradientBrush>

    <!-- 2. Completed（已完成）- 高对比绿 -->
    <LinearGradientBrush x:Key="IndexSummaryTodoCompletedGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#008000" Offset="1"/>
        <!-- 高对比绿，非荧光 -->
    </LinearGradientBrush>

    <!-- 3. CompletionRate（完成率）- 高对比橙 -->
    <LinearGradientBrush x:Key="IndexSummaryTodoCompletionRateGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#E67700" Offset="1"/>
        <!-- 高对比橙，低饱和 -->
    </LinearGradientBrush>

    <!-- 4. MemoTotal（备忘录）- 高对比紫 -->
    <LinearGradientBrush x:Key="IndexSummaryMemoTotalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#6B21A8" Offset="1"/>
        <!-- 高对比紫，不刺眼 -->
    </LinearGradientBrush>

    <!-- 5. Custom（自定义）- 高对比青 -->
    <LinearGradientBrush x:Key="IndexSummaryCustomGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#00796B" Offset="1"/>
        <!-- 高对比青，柔和 -->
    </LinearGradientBrush>

    <!-- ==================== 首页数据区域Boder渐变颜色 ==================== -->
    <!-- 待办：深暗底 → 亮青（高对比，不刺眼） -->
    <LinearGradientBrush x:Key="IndexToDoDataGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <!-- 顶部：极浅冰蓝（黑字最清晰） -->
        <GradientStop Color="#F2F9FC" Offset="0.0"/>
        <!-- 上中：浅青绿（过渡自然） -->
        <GradientStop Color="#D1FAE5" Offset="0.4"/>
        <!-- 下中：亮青绿（核心视觉，黑字清晰） -->
        <GradientStop Color="#6EE7B7" Offset="0.7"/>
        <!-- 底部：超亮青绿（亮度拉满，黑字绝不发闷） -->
        <GradientStop Color="#5EEAD4" Offset="1.0"/>
    </LinearGradientBrush>
    <!-- 备忘录：深灰紫 → 亮紫（高对比，和待办呼应） -->
    <LinearGradientBrush x:Key="IndexMemoDataGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <!-- 左侧：极浅冰紫（黑字最清晰） -->
        <GradientStop Color="#FAF5FF" Offset="0.0"/>
        <!-- 左中：浅紫（过渡） -->
        <GradientStop Color="#F3E8FF" Offset="0.3"/>
        <!-- 中间：中紫（核心视觉） -->
        <GradientStop Color="#E9D5FF" Offset="0.6"/>
        <!-- 右中：亮紫（提升亮度） -->
        <GradientStop Color="#D8B4FE" Offset="0.8"/>
        <!-- 右侧：超亮紫（亮度拉满，黑字清晰） -->
        <GradientStop Color="#C084FC" Offset="1.0"/>
    </LinearGradientBrush>
</ResourceDictionary>