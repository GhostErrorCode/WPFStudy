<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 自定义明亮主题颜色 -->

    <!-- 白色文本 -->
    <SolidColorBrush x:Key="TextFillColorWhiteBrush" Color="#FFFFFF"/>

    <!-- ==================== 首页汇总区域Boder渐变颜色 ==================== -->
    <!-- 1. ToDoTotal（汇总/待办总量）- 柔和蓝渐变 -->
    <LinearGradientBrush x:Key="IndexSummaryToDoTotalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F0F7FF" Offset="0"/>
        <!-- 极浅蓝底，不刺眼 -->
        <GradientStop Color="#4A90E2" Offset="1"/>
        <!-- 柔和蓝，低饱和 -->
    </LinearGradientBrush>

    <!-- 2. Completed（已完成）- 柔和绿渐变 -->
    <LinearGradientBrush x:Key="IndexSummaryTodoCompletedGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F0F9F0" Offset="0"/>
        <!-- 极浅绿底 -->
        <GradientStop Color="#38B000" Offset="1"/>
        <!-- 柔和草绿，不刺眼 -->
    </LinearGradientBrush>

    <!-- 3. CompletionRate（完成率）- 柔和琥珀渐变 -->
    <LinearGradientBrush x:Key="IndexSummaryTodoCompletionRateGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFF8E6" Offset="0"/>
        <!-- 极浅橙底 -->
        <GradientStop Color="#F59E0B" Offset="1"/>
        <!-- 柔和琥珀色，低饱和 -->
    </LinearGradientBrush>

    <!-- 4. MemoTotal（备忘录）- 柔和紫渐变 -->
    <LinearGradientBrush x:Key="IndexSummaryMemoTotalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#F8F0FF" Offset="0"/>
        <!-- 极浅紫底 -->
        <GradientStop Color="#8B5CF6" Offset="1"/>
        <!-- 柔和浅紫，不刺眼 -->
    </LinearGradientBrush>

    <!-- 5. Custom（自定义汇总）- 柔和青渐变 -->
    <LinearGradientBrush x:Key="IndexSummaryCustomGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E6FFFA" Offset="0"/>
        <!-- 极浅青底 -->
        <GradientStop Color="#06B6D4" Offset="1"/>
        <!-- 柔和青绿色，低饱和 -->
    </LinearGradientBrush>

    <!-- ==================== 首页数据区域Boder渐变颜色 ==================== -->
    <!-- 待办：柔青 → 浅绿（明亮系，对比明显不刺眼） -->
    <LinearGradientBrush x:Key="IndexToDoDataGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0.0"/>
        <!-- 左上角纯白（黑字清晰） -->
        <GradientStop Color="#D1FAE5" Offset="0.3"/>
        <!-- 中间浅青绿（主色#10B981浅化） -->
        <GradientStop Color="#A7F3D0" Offset="1.0"/>
        <!-- 右下角柔青绿（主色进一步浅化） -->
    </LinearGradientBrush>
    <!-- 备忘录：柔紫 → 浅紫（明亮系，层次清晰） -->
    <LinearGradientBrush x:Key="IndexMemoDataGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F9FAFB" Offset="0.0"/>
        <!-- 左上角雾白（黑字清晰） -->
        <GradientStop Color="#EDE9FE" Offset="0.3"/>
        <!-- 中间浅紫蓝（主色#7C3AED浅化） -->
        <GradientStop Color="#DDD6FE" Offset="1.0"/>
        <!-- 右下角柔紫蓝（主色进一步浅化） -->
    </LinearGradientBrush>
</ResourceDictionary>