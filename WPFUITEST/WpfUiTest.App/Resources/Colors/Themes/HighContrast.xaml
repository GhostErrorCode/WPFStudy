<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 自定义高对比度主题颜色 -->

    <!-- 白色文本 -->
    <SolidColorBrush x:Key="TextFillColorWhiteBrush" Color="#FFFFFF"/>

    <!-- ==================== 首页汇总区域Boder渐变颜色 ==================== -->
    <!-- 1. ToDoTotal（汇总）- 高对比蓝（不刺眼版） -->
    <LinearGradientBrush x:Key="IndexSummaryToDoTotalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <!-- 高对比基础白 -->
        <GradientStop Color="#0050CC" Offset="1"/>
        <!-- 高对比蓝，低饱和不刺眼 -->
    </LinearGradientBrush>

    <!-- 2. Completed（已完成）- 高对比绿 -->
    <LinearGradientBrush x:Key="IndexSummaryTodoCompletedGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#008000" Offset="1"/>
        <!-- 高对比绿，非荧光 -->
    </LinearGradientBrush>

    <!-- 3. CompletionRate（完成率）- 高对比橙 -->
    <LinearGradientBrush x:Key="IndexSummaryTodoCompletionRateGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#E67700" Offset="1"/>
        <!-- 高对比橙，低饱和 -->
    </LinearGradientBrush>

    <!-- 4. MemoTotal（备忘录）- 高对比紫 -->
    <LinearGradientBrush x:Key="IndexSummaryMemoTotalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#6B21A8" Offset="1"/>
        <!-- 高对比紫，不刺眼 -->
    </LinearGradientBrush>

    <!-- 5. Custom（自定义）- 高对比青 -->
    <LinearGradientBrush x:Key="IndexSummaryCustomGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#00796B" Offset="1"/>
        <!-- 高对比青，柔和 -->
    </LinearGradientBrush>

    <!-- ==================== 首页数据区域Boder渐变颜色 ==================== -->
    <!-- 待办：深暗底 → 亮青（高对比，不刺眼） -->
    <LinearGradientBrush x:Key="IndexToDoDataGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#EFF6FF" Offset="0.0"/>
        <!-- 左上角浅冰白（黑字清晰） -->
        <GradientStop Color="#6EE7B7" Offset="0.3"/>
        <!-- 中间中青绿（主色#10B981中饱和版） -->
        <GradientStop Color="#10B981" Offset="1.0"/>
        <!-- 右下角亮青绿（核心主色，强化对比） -->
    </LinearGradientBrush>
    <!-- 备忘录：深灰紫 → 亮紫（高对比，和待办呼应） -->
    <LinearGradientBrush x:Key="IndexMemoDataGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F5F3FF" Offset="0.0"/>
        <!-- 左上角浅冰紫（黑字清晰） -->
        <GradientStop Color="#A855F7" Offset="0.3"/>
        <!-- 中间中紫蓝（主色#7C3AED中饱和版） -->
        <GradientStop Color="#7C3AED" Offset="1.0"/>
        <!-- 右下角亮紫蓝（核心主色，强化对比） -->
    </LinearGradientBrush>
</ResourceDictionary>