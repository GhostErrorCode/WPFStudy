{
  "AppSettings": {
    // 应用名称：可在代码中读取，用于窗口标题、日志标识、关于窗口展示等
    "AppName": "WpfUiTest",
    // 应用版本号：用于版本展示、版本校验、更新检测等
    "Version": "1.0.0",
    // 应用运行环境标识：标记当前是「开发环境（Development）」
    // 注意：.NET默认会读取「根节点」的 Environment 属性来加载环境专属配置（如 appsettings.Development.json）
    // 你此处放在 AppSettings 里，代码无法自动识别，建议移到根节点（见下文优化）
    "Environment": "Development"
  },
  "ConnectionStrings": {
    // SQLite数据库连接字符串（核心属性）
    // Data Source：指定SQLite数据库文件的路径，此处为「相对路径」
    // → 实际指向应用运行目录（如 bin/Debug/net10-windows/）下的 WpfUiTest.db 文件
    // 补充（单机应用优化）：建议添加 Cache=Shared 避免SQLite多线程锁表，修改后：
    // "DefaultConnection": "Data Source=WpfUiTest.db;Cache=Shared"
    "DefaultConnection": "DataBase/WpfUiTest.db;Cache=Shared",
    "DefaultDir": "DataBase"
  },
  "Logging": {
    "LogLevel": {
      // 全局默认日志级别：只输出 Information 及以上级别的日志
      // 日志级别优先级：Verbose < Debug < Information < Warning < Error < Fatal
      // 此处设为 Information → Debug/Verbose 级别的日志会被过滤，只保留 Info/Warn/Error/Fatal
      "Default": "Information",
      // 过滤微软官方组件（如EF Core、ASP.NET Core、.NET内置组件）的日志
      // 仅输出 Warning 及以上级别，避免微软组件的底层冗余日志（如数据库连接细节）
      "Microsoft": "Warning",
      // 过滤.NET System命名空间下组件的日志，同样仅输出 Warning 及以上级别
      "System": "Warning"
    }
  },
  // 登录凭证
  "Credential": {
    "Directory": "Cache", // 凭证目录名
    "FileName": "loginCache.dat", // 凭证文件名
    "ExpireDays": 30  // 默认过期时间30天
  }
}