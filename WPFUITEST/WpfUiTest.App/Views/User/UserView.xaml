<ui:FluentWindow x:Class="WpfUiTest.App.Views.User.UserView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:behavior="clr-namespace:WpfUiTest.Shared.Behaviors;assembly=WpfUiTest.Shared"
        xmlns:local="clr-namespace:WpfUiTest.App.Views.User"
        mc:Ignorable="d"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen"
        Title="UserView" Height="500" Width="850"
        MinHeight="450" MinWidth="800"
        MaxHeight="560" MaxWidth="940">
    <!-- ===============================================
    ExtendsContentIntoTitleBar: 控制窗口内容是否延伸到系统默认的标题栏区域
    WindowBackdropType: 背景视觉效果
    WindowCornerPreference: 窗口的边角样式
    ================================================= -->
    <Grid>
        <!-- 主页面分成两行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- 第一行: 标题栏 -->
        <ui:TitleBar
            Grid.Row="0"
            Style="{StaticResource UserViewUITitleBarStyle}">
            <!-- 标题栏图标 -->
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/GhostToDo;component/Resources/Images/User.jpg" />
            </ui:TitleBar.Icon>
            <!-- 标题栏标题文本 直接设置Title或Header可能导致无法图标和标题无法对齐-->
            <ui:TitleBar.Header>
                <ui:TextBlock Text="UserView" VerticalAlignment="Center" />
            </ui:TitleBar.Header>
        </ui:TitleBar>

        
        <!-- 第二行: 内容区 -->
        <Grid Grid.Row="1">
            <!-- 第二行再分两列 -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.0*" />
            </Grid.ColumnDefinitions>
            <!-- 第二行第一列: 登录注册界面图片-->
            <!-- 图片容器：居中显示，填满左列 -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource UserLeftImageBorderStyle}">
                <ui:Image Source="pack://application:,,,/GhostToDo;component/Resources/Images/User.jpg" Style="{StaticResource UserLeftUIImageStyle}" />
            </Border>
            <!-- 第二行第二列: 登录/注册功能-->
            <!-- 注册页面 -->
            <StackPanel
                x:Name="RegisterView"
                Grid.Row="1" Grid.Column="1"
                Style="{StaticResource RegisterStackPanelStyle}">
                <!-- 注册标题 -->
                <ui:TextBlock Text="注册" Style="{StaticResource TitleTwoUiTextBlockStyle}" />
                <!-- 卡片 -->
                <ui:Card>
                    <StackPanel Orientation="Vertical">
                        <!-- 注册用户 -->
                        <ui:TextBox Text="{Binding UserRegisterViewModel.Account}" PlaceholderText="请输入账户..." Style="{StaticResource InputUiTextBoxStyle}" />
                        <ui:TextBox Text="{Binding UserRegisterViewModel.UserName}" PlaceholderText="请输入昵称..." Style="{StaticResource InputUiTextBoxStyle}" />
                        <ui:PasswordBox behavior:PasswordBoxBindingBehavior.Password="{Binding UserRegisterViewModel.Password,Mode=TwoWay}" PlaceholderText="请输入密码..." Style="{StaticResource UiPasswordBoxStyle}" />
                        <ui:PasswordBox behavior:PasswordBoxBindingBehavior.Password="{Binding UserRegisterViewModel.ConfirmPassword,Mode=TwoWay}" PlaceholderText="请再次输入密码..." Style="{StaticResource UiPasswordBoxStyle}" />
                    </StackPanel>
                    <!-- 卡片页脚 -->
                    <ui:Card.Footer>
                        <!-- 用 Gird 容器分成两列，左放返回登录，右放注册 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <!-- 返回登录按钮 -->
                            <ui:Button
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Icon="{ui:SymbolIcon Symbol=ArrowHookDownLeft24}"
                                Content="返回登录"
                                Margin="0,5,5,5"
                                Command="{Binding SwitchUserViewTypeCommand}"
                                Style="{StaticResource SecondaryUiButtonStyle}" />
                            <!-- 注册按钮 -->
                            <ui:Button
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Icon="{ui:SymbolIcon Symbol=PersonAdd24}"
                                Content="注册"
                                Command="{Binding UserRegisterCommand}"
                                Style="{StaticResource PrimaryUiButtonStyle}"/>
                        </Grid>
                    </ui:Card.Footer>
                </ui:Card>
            </StackPanel>

            <!-- 登录页面 -->
            <StackPanel
                x:Name="LoginView"
                Grid.Row="1" Grid.Column="1"
                Style="{StaticResource LoginStackPanelStyle}">
                <!-- 登录标题 -->
                <ui:TextBlock Text="登录" Style="{StaticResource TitleTwoUiTextBlockStyle}" />
                <!-- 卡片 -->
                <ui:Card>
                    <StackPanel Orientation="Vertical">
                        <!-- 登录用户 -->
                        <ui:TextBox Text="{Binding UserLoginViewModel.Account}" PlaceholderText="请输入账户..." Style="{StaticResource InputUiTextBoxStyle}" />
                        <ui:PasswordBox behavior:PasswordBoxBindingBehavior.Password="{Binding UserLoginViewModel.Password,Mode=TwoWay}" PlaceholderText="请输入密码..." Style="{StaticResource UiPasswordBoxStyle}" />
                        <CheckBox IsChecked="{Binding UserLoginViewModel.IsRememberMe}" Content="记住我" Style="{StaticResource CheckBoxStyle}"/>
                    </StackPanel>
                    <!-- 卡片页脚 -->
                    <ui:Card.Footer>
                        <!-- 用 Gird 容器分成两列，左放返回登录，右放注册 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <!-- 去注册 -->
                            <ui:Button
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Icon="{ui:SymbolIcon Symbol=ArrowCircleLeft24}"
                                Content="前往注册"
                                Margin="0,5,5,5"
                                Command="{Binding SwitchUserViewTypeCommand}"
                                Style="{StaticResource SecondaryUiButtonStyle}" />
                            <!-- 登录按钮 -->
                            <ui:Button
                                x:Name="LoginButton"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Icon="{ui:SymbolIcon Symbol=Key24}"
                                Content="登录"
                                Command="{Binding UserLoginCommand}"
                                Style="{StaticResource PrimaryUiButtonStyle}"/>
                        </Grid>
                    </ui:Card.Footer>
                </ui:Card>
            </StackPanel>
        </Grid>
        
        <!-- 第三行 弹窗区域 Z值给大点，确保它永远是最上层-->
        <ui:SnackbarPresenter x:Name="UserSnackbarPresenter" Grid.Row="1" Panel.ZIndex="10" />
    </Grid>
</ui:FluentWindow>
