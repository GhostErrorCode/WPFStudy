<Page x:Class="WpfUiTest.App.Views.Main.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:WpfUiTest.App.Views.Main"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsView">

    <Grid>
        <StackPanel Orientation="Vertical">
            <!-- 标题 -->
            <!-- 由于一些未知原因（加载时机不对？）导致暗黑主题下，StackPanel容器下的直接控件不会切换到暗黑主题对应颜色，需要手动添加WPFUI主题资源 -->
            <ui:TextBlock
                Text="设置"
                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                Style="{StaticResource TitleOneUiTextBlockStyle}"
                />
            <!-- 列表小标题 -->
            <ui:TextBlock
                Margin="0,0,0,8"
                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                FontTypography="BodyStrong"
                Text="主题"
                />
            <!-- 应用主题的设置 CardControl-->
            <ui:CardControl Icon="{ui:SymbolIcon Symbol=Color24}">
                <!-- 设置头部区域 -->
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock
                            Grid.Row="0"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush }"
                            Text="应用主题"
                            />
                        <ui:TextBlock
                            Grid.Row="1"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush }"
                            Text="更改应用显示主题"
                            />
                    </Grid>
                </ui:CardControl.Header>
                <!-- 设置组合框区域 -->
                <ComboBox
                    MinWidth="200"
                    ItemsSource="{Binding SettingsThemeViewModel.ThemeOptions}"
                    SelectedItem="{Binding SettingsThemeViewModel.CurrentTheme}"
                    >
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <ui:TextBlock Text="{Binding Converter={StaticResource ThemeToStringConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </ui:CardControl>


            <!-- 列表小标题 -->
            <ui:TextBlock
                Margin="0,24,0,8"
                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                FontTypography="BodyStrong"
                Text="用户"
                />
            <!-- 用户的设置 CardControl-->
            <ui:CardControl Icon="{ui:SymbolIcon Symbol=Person24}">
                <!-- 设置头部区域 -->
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock
                            Grid.Row="0"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush }"
                            Text="当前用户"
                            />
                        <ui:TextBlock
                            Grid.Row="1"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush }"
                            Text="{Binding SettingsUserViewModel.UserName}"
                            />
                    </Grid>
                </ui:CardControl.Header>
                <ui:Button
                    Content="登出当前用户"
                    Margin="0"
                    Icon="{ui:SymbolIcon Symbol=PersonArrowBack24}"
                    Foreground="{DynamicResource TextFillColorWhiteBrush}"
                    Command="{Binding SettingsUserViewModel.UserLogoutCommand}"
                    Style="{StaticResource CautionUiButtonStyle}"
                      />
            </ui:CardControl>


            <!-- 关于此应用 -->
            <!-- 小标题 -->
            <ui:TextBlock
                Margin="0,24,0,8"
                Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                FontTypography="BodyStrong"
                Text="关于"
                />
            <!-- 可展开扩展面板的卡片 -->
            <ui:CardExpander
                ContentPadding="0"
                Icon="{ui:ImageIcon 'pack://application:,,,/WpfUiTest.App;component/Resources/Images/User.jpg', Width=38, Height=35}"
                >
                <!-- 顶层区域（左侧+右侧） -->
                <ui:CardExpander.Header>
                    <Grid>
                        <!-- Gird分2行2列 -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 左侧上方区域 -->
                        <ui:TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            FontTypography="Body"
                            Text="{Binding SettingsAboutViewModel.AppName}"
                            />
                        <!-- 左侧下方区域 -->
                        <ui:TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="© 2026 GhostErrorCode"
                            />
                        <!-- 右侧区域 -->
                        <ui:TextBlock
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SettingsAboutViewModel.Version}"
                            />
                    </Grid>
                </ui:CardExpander.Header>
                <!-- 下拉的扩展区域 -->
                <StackPanel Orientation="Vertical">
                    <!-- 仓库克隆地址 -->
                    <Grid Margin="16,16,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock
                            Grid.Column="0"
                            Text="克隆此仓库"
                            />
                        <ui:TextBlock
                            Grid.Column="1"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SettingsAboutViewModel.CloneGitHubRepositoryAddress}"
                            />
                    </Grid>
                    <Separator />
                    <!-- 数据库文件路径 -->
                    <Grid Margin="16,16,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock
                            Grid.Column="0"
                            Text="数据库目录"
                            />
                        <ui:TextBlock
                            Grid.Column="1"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SettingsAboutViewModel.DataBaseDirectory}"
                            />
                    </Grid>
                    <Separator />
                    <!-- 日志文件路径 -->
                    <Grid Margin="16,16,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock
                            Grid.Column="0"
                            Text="日志目录"
                            />
                        <ui:TextBlock
                            Grid.Column="1"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SettingsAboutViewModel.LogDirectory}"
                            />
                    </Grid>
                    <Separator />
                    <!-- 缓存文件路径 -->
                    <Grid Margin="16,16,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock
                            Grid.Column="0"
                            Text="登录凭证目录"
                            />
                        <ui:TextBlock
                            Grid.Column="1"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SettingsAboutViewModel.LoginCredentialDirectory}"
                            />
                    </Grid>
                    <Separator />
                    <!-- 设置文件路径 -->
                    <Grid Margin="16,16,16,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock
                            Grid.Column="0"
                            Text="设置目录"
                            />
                        <ui:TextBlock
                            Grid.Column="1"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                            Text="{Binding SettingsAboutViewModel.SettingsDirectory}"
                            />
                    </Grid>
                    <!-- 超链: 仓库地址 -->
                    <ui:Anchor
                        BorderThickness="0,1,0,1"
                        NavigateUri="{Binding SettingsAboutViewModel.GitHubRepositoryAddress}"
                        Style="{StaticResource SettingsUiAnchorStyle}"
                        >
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="前往此项目Github仓库" />
                            <ui:SymbolIcon Grid.Column="1" Symbol="Link24" />
                        </Grid>
                    </ui:Anchor>

                    <!-- 版本号 -->
                    <ui:TextBlock
                        Margin="16,16,16,16"
                        Text="{Binding SettingsAboutViewModel.Version}"
                        />
                </StackPanel>
            </ui:CardExpander>
        </StackPanel>
    </Grid>
</Page>
