<Page x:Class="WpfUiTest.App.Views.Main.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:WpfUiTest.App.Views.Main"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsView">

    <Grid>
        <StackPanel Orientation="Vertical">
            <!-- 标题 -->
            <ui:TextBlock
                Text="设置"
                Style="{StaticResource TitleTwoUiTextBlockStyle}"
                />
            
            <!-- 列表小标题 -->
            <ui:TextBlock
                FontTypography="BodyStrong"
                Text="主题"
                />
            <!-- 应用主题的设置 CardControl-->
            <ui:CardControl Icon="{ui:SymbolIcon Symbol=Color24}">
                <!-- 设置头部区域 -->
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock
                            Grid.Row="0"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush }"
                            Text="应用主题" />
                        <ui:TextBlock
                            Grid.Row="1"
                            FontTypography="Body"
                            Foreground="{ui:ThemeResource TextFillColorSecondaryBrush }"
                            Text="更改应用显示主题" />
                    </Grid>
                </ui:CardControl.Header>
                <!-- 设置组合框区域 -->
                <ComboBox
                    MinWidth="200"
                    SelectedIndex="0"
                    >
                    <ComboBoxItem Content="明亮" Tag="Light" />
                    <ComboBoxItem Content="暗黑" Tag="Dark" />
                    <ComboBoxItem Content="高对比度" Tag="High Contrast" />
                </ComboBox>
            </ui:CardControl>
        </StackPanel>
    </Grid>
</Page>
