{
  // 应用程序设置
  "AppSettings": {
    // 应用名称
    "AppName": "GhostWpfUiTest",
    // 版本号
    "Version": "alpha-v0.0.1",
    // 当前运行环境标识
    "Environment": "Development"
  },

  // 数据库设置
  "DataBaseSettings": {
    // 数据库文件目录
    "Directory": "DataBase",
    // 数据库连接串
    "Connection": "DataBase/WpfUiTest.db;Cache=Shared"
  },

  // 日志设置
  "LogSettings": {
    // 日志文件目录
    "Directory": "Logs",
    // 日志输出等级
    "LogLevel": {
      // 全局默认日志级别：只输出 Information 及以上级别的日志
      // 日志级别优先级：Verbose < Debug < Information < Warning < Error < Fatal
      // 此处设为 Information → Debug/Verbose 级别的日志会被过滤，只保留 Info/Warn/Error/Fatal
      "Default": "Information",
      // 过滤微软官方组件（如EF Core、ASP.NET Core、.NET内置组件）的日志
      // 仅输出 Warning 及以上级别，避免微软组件的底层冗余日志（如数据库连接细节）
      "Microsoft": "Warning",
      // 过滤.NET System命名空间下组件的日志，同样仅输出 Warning 及以上级别
      "System": "Warning"
    }
  },

  // 登录凭证设置
  "CredentialSettings": {
    // 凭证目录名
    "Directory": "Cache",
    // 凭证文件名
    "FileName": "loginCache.dat",
    // 默认过期时间30天
    "ExpireDays": 30
  },

  // 应用主题设置
  "ThemeSettings": {
    // 应用主题
    "Theme": "Light"
  }
}