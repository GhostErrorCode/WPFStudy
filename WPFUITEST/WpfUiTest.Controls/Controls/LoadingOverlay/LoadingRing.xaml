<UserControl x:Class="WpfUiTest.Controls.Controls.LoadingOverlay.LoadingRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:WpfUiTest.Controls.Controls.LoadingOverlay"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="LoadingRingUserControl">
    <Grid>
        <!-- 环形加载动画 -->
        <Grid
            Grid.RowSpan="3"
            Grid.ColumnSpan="2"
            Visibility="{Binding IsLoading, ElementName=LoadingRingUserControl, Converter={StaticResource BooleanToVisibilityConverter}}"
            >
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource LoadingeBrush}"
                Orientation="Vertical"
                >
                <ui:ProgressRing
                    IsIndeterminate="True"
                    Width="60"
                    Height="60"
                    Margin="80,20,80,20"
                    />
                <ui:TextBlock
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="Bold"
                    Margin="0,0,0,20"
                    Text="{Binding LoadingText, ElementName=LoadingRingUserControl}"
                    Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"
                    />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
