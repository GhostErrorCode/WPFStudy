<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                    >
    <!-- 页码按钮样式 -->
    <Style
        x:Key="PageNumberUiButtonStyle"
        TargetType="{x:Type ui:Button}"
        BasedOn="{StaticResource {x:Type ui:Button}}"
        >
        <!-- 这里只给最小宽度，让按钮可随着内容撑起来 -->
        <Setter Property="MinWidth" Value="35" />
        <Setter Property="Height" Value="35" />
        <Setter Property="Appearance" Value="Transparent" />
        <Setter Property="Margin" Value="2,2,2,2" />
        <Setter Property="Padding" Value="5,5,5,5" />
    </Style>

    <!-- 总条数TextBlock样式 -->
    <Style x:Key="TotalCountTextBlockStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Height" Value="35" />
        <Setter Property="Margin" Value="0,0,10,0" />
        <Setter Property="Padding" Value="5,7,5,5" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{ui:ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
</ResourceDictionary>