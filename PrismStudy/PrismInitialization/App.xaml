<prism:PrismApplication x:Class="PrismInitialization.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:local="clr-namespace:PrismInitialization">

</prism:PrismApplication>

<!-- 
    prism:PrismApplication：将应用程序基类从WPF标准的Application改为Prism提供的PrismApplication，这是Prism应用的起点
    x:Class="PrismDemo.App"：指定代码后台类（请将PrismDemo替换为你的项目命名空间）
    xmlns:prism="http://prismlibrary.com/"：引入Prism的XAML命名空间，这样才能使用Prism的特性和控件
-->