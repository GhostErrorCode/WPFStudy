<UserControl x:Class="MemoDesktop.Views.Dialogs.MsgDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoDesktop.Views.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Width="400" Height="250">
    <Grid>
        <!-- 分3行 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
            <RowDefinition Height="70" />
        </Grid.RowDefinitions>
        
        <!-- 第一行 -->
        <TextBlock
            Margin="10,10,10,10"
            Grid.Row="0"
            d:Text="温馨提示"
            Text="{Binding Title}"
            Padding="5,5,5,5"
            FontSize="20"
            />
        
        <!-- 第二行 -->
        <TextBlock
            Margin="10,0,10,10"
            Grid.Row="1"
            d:Text="确认关闭此软件吗?"
            Text="{Binding Content}"
            Padding="15,0,15,0"
            FontSize="16"
            VerticalAlignment="Center"
            />

        <!-- 第三行的按钮区域 -->
        <StackPanel Margin="10,10,10,10" Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right">
            <Button Content="取消" Margin="0,0,10,0" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}"/>
            <Button Content="确认" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
