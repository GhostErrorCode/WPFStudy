<UserControl x:Class="MemoDesktop.Views.MemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:MemoDesktop.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <materialDesign:DialogHost>
        <!-- 右侧添加栏 -->
        <materialDesign:DrawerHost IsRightDrawerOpen="{Binding IsRightDrawerOpen}">
            <materialDesign:DrawerHost.RightDrawerContent>
                <DockPanel Width="300" LastChildFill="False">
                    <TextBlock Text="添加/修改备忘录" FontSize="20" FontWeight="Bold" DockPanel.Dock="Top" Padding="20"/>
                    <TextBox Margin="20,0,20,20" materialDesign:HintAssist.Hint="请输入备忘录标题..." DockPanel.Dock="Top" Text="{Binding AddOrUpdateMemoData.Title, Mode=TwoWay}" />
                    <TextBox Margin="20,0,20,20" materialDesign:HintAssist.Hint="请输入备忘录内容..." DockPanel.Dock="Top" MinHeight="100" TextWrapping="Wrap" VerticalContentAlignment="Top" Text="{Binding AddOrUpdateMemoData.Content}" />
                    <Button Margin="20,0,20,0" Content="保存备忘录" DockPanel.Dock="Top" Command="{Binding SaveMemoDataCommand}" Cursor="Hand" />
                </DockPanel>
            </materialDesign:DrawerHost.RightDrawerContent>

            <Grid>
                <!-- 分成两行 -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 第一行的搜索框以及添加按钮 -->
                <StackPanel Grid.Row="0" Margin="10,10,0,0" Orientation="Horizontal">
                    <!-- 查询输入框 -->
                    <!-- materialDesign:TextFieldAssist.HasClearButton="True，是否开启编辑时右侧清除按钮 -->
                    <!--
                    模式	        触发时机	                    典型用途
                    Default	        默认值，不同控件不同	        TextBox：LostFocus；CheckBox：PropertyChanged
                    PropertyChanged	实时更新，每次输入都触发	    搜索框、实时验证、即时计算
                    LostFocus	    控件失去焦点时更新	            表单输入（默认）
                    Explicit	    手动调用 UpdateSource() 时更新	需要按钮确认的输入
                    -->
                    <TextBox
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Width="250"
                        VerticalAlignment="Center"
                        materialDesign:HintAssist.Hint="查询待办事项..."
                        materialDesign:TextFieldAssist.HasClearButton="True">
                        <!-- 搜索框的回车事件 -->
                        <TextBox.InputBindings>
                            <KeyBinding
                                Key="Enter"
                                Command="{Binding SelectMemoDataByConditionCommand}"
                                />
                        </TextBox.InputBindings>
                    </TextBox>
                </StackPanel>

                <!-- 第一行的添加待办按钮 -->
                <Button Command="{Binding AddMemoDataCommand}"  Content=" + 添加备忘录" HorizontalAlignment="Right" Margin="0,10,10,0" Cursor="Hand"/>

                <!-- ########################################################################################################## -->

                <!-- 显示搜索为空的时候提示信息 -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" Visibility="{Binding SelectedMemoDataCollection.Count, Converter={StaticResource IntToVisibilityConverter}}">
                    <!-- 提示图片 -->
                    <Image Source="/MemoDesktop;component/Assets/Images/新之助.jpg" Width="120" Height="120"/>
                    <!-- 提示文本 -->
                    <TextBlock Text="未搜索到对应数据" Margin="0,10,0,0" FontSize="28" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- 第二行内容：ItemsControl -->
                <ScrollViewer Grid.Row="1"  Margin="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding SelectedMemoDataCollection}" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <!-- 先定义容器类型 -->
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <!-- 在定义数据模板 -->
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!--进入时的动画-->
                                <materialDesign:TransitioningContent OpeningEffect="{materialDesign:TransitionEffect Kind=ExpandIn}">
                                    <!-- 分两行 -->
                                    <Grid Width="220" MinHeight="180" MaxHeight="250" Margin="10">
                                        <!-- 设置一个鼠标左键弹起时的操作 -->
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <i:InvokeCommandAction
                                                    Command="{Binding DataContext.SelectedMemoDataCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- 右上角三点按钮 -->
                                        <materialDesign:PopupBox HorizontalAlignment="Right" Panel.ZIndex="1">
                                            <Button
                                                Content="删除"
                                                Command="{Binding DataContext.DeleteMemoDataCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                />
                                        </materialDesign:PopupBox>

                                        <!-- Border负责背景色和圆角 -->
                                        <Border
                                            Grid.RowSpan="2"
                                            Background="#1E90FF"
                                            CornerRadius="10" />

                                        <!-- 具体的数据项 -->
                                        <TextBlock Padding="10,10,10,10" Grid.Row="0" Text="{Binding Title}" FontWeight="Bold" />
                                        <TextBlock Grid.Row="1" Padding="10,10,10,10" Text="{Binding Content}" />

                                        <!-- 右侧圆底花纹 -->
                                        <Canvas Grid.RowSpan="2" ClipToBounds="True">
                                            <!-- ClipToBounds裁剪超出边界的元素 -->
                                            <Border
                                                Canvas.Top="10"
                                                Canvas.Right="-50"
                                                CornerRadius="100"
                                                Width="120"
                                                Height="120"
                                                Background="#FFFFFF"
                                                Opacity="0.1" />
                                            <Border
                                                Canvas.Top="80"
                                                Canvas.Right="-30"
                                                CornerRadius="100"
                                                Width="120"
                                                Height="120"
                                                Background="#FFFFFF"
                                                Opacity="0.1" />
                                        </Canvas>
                                    </Grid>
                                </materialDesign:TransitioningContent>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</UserControl>
