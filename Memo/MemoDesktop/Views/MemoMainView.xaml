<Window x:Class="MemoDesktop.Views.MemoMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MemoDesktop.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialDesignConverters="clr-namespace:MaterialDesignThemes.Wpf.Converters;assembly=MaterialDesignThemes.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:constants="clr-namespace:MemoDesktop.Constants"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        WindowStyle="None"
        Style="{StaticResource MaterialDesignWindow}"
        ResizeMode="CanResize" 
        AllowsTransparency="False"
        Title="MemoMainView" Height="800" Width="1300">
    <!-- AllowsTransparency="False"确保关闭，以获得更好性能 -->
    <!-- ResizeMode="CanResize" 保持可调整大小 -->
    <!-- WindowStyle="None"移除标题栏、边框及所有系统按钮,但会失去Win的原生动画 -->
    <!-- xmlns:i="http://schemas.microsoft.com/xaml/behaviors"在 XAML 中无代码实现 “事件与命令 / 行为的绑定”,在 XAML 中无代码实现 “事件与命令 / 行为的绑定” -->

    <!-- 使用WindowChrome，这是WPF中更强大、性能更优的自定义窗口方案。它可以精细控制非客户区，从根本上避免白边，甚至能解决启动时的白屏问题 -->
    <shell:WindowChrome.WindowChrome>
        <!-- 关键：通过WindowChrome接管非客户区 -->
        <shell:WindowChrome
            CaptionHeight="0" 
            ResizeBorderThickness="3"/>
        <!-- CaptionHeight="0" 将标题栏区域高度设为0，隐藏系统默认区域 -->
        <!-- ResizeBorderThickness="6"调整边框的厚度，可根据需要修改 -->
    </shell:WindowChrome.WindowChrome>
    <!-- 你的窗口内容 -->


    <materialDesign:DialogHost 
                               x:Name="MemoMainViewDialogHost"
                               DialogTheme="Inherit"
                               Identifier="RootDialog"
                               SnackbarMessageQueue="{Binding ElementName=MainSnackbar, Path=MessageQueue}">

        <materialDesign:DrawerHost x:Name="MemoMainViewDrawerHost" IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}">
            <materialDesign:DrawerHost.LeftDrawerContent>
                <DockPanel MinWidth="220" LastChildFill="False">
                    <!-- LastChildFill关闭/开启最后一个子元素填充所有剩余空间 -->
                    <!-- 上方的头像和昵称显示区域 -->
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Top">
                        <!-- 嵌入资源使用以下路径    /项目名;component/路径 -->
                        <Image Source="/MemoDesktop;component/Assets/Images/新之助.jpg" Width="50" Height="50" Margin="0,30,0,0">
                            <Image.Clip>
                                <!-- 使用EllipseGeometry进行圆形裁剪 -->
                                <EllipseGeometry Center="25,25" RadiusX="25" RadiusY="25"/>
                            </Image.Clip>
                        </Image>
                        <!-- 名称显示区域 -->
                        <TextBlock Margin="0,10,0,0" Text="幽灵" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- 下方的ListBox菜单列表 -->
                    <ListBox x:Name="LeftMenuListBox" ItemContainerStyle="{StaticResource LeftMenuBarStyle}" ItemsSource="{Binding MenuBars}" DockPanel.Dock="Top" Margin="0,30,0,0">
                        <!-- 交互触发器：连接UI事件与ViewModel命令的桥梁 -->
                        <i:Interaction.Triggers>
                            <!-- 事件触发器：监听ListBox的SelectionChanged事件 -->
                            <i:EventTrigger EventName="SelectionChanged">
                                <!-- Prism行为：将触发的事件转换为对ViewModel中命令的调用 -->
                                <i:InvokeCommandAction
                                    Command="{Binding NavigateCommand}" 
                                    CommandParameter="{Binding SelectedItem, ElementName=LeftMenuListBox}"/>
                                    <!-- 关键：将ListBox当前选中的对象作为参数传递给命令 -->
                                    <!-- Command="{Binding MenuItemClickedCommand}" 绑定到要执行的命令 -->
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <!-- 定义数据模板，需要显示图标和菜单名称 -->
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                    <!-- 菜单图标 -->
                                    <materialDesign:PackIcon Kind="{Binding Icon}" Margin="10,0,0,0" VerticalAlignment="Center" Padding="0"/>
                                    <!-- 菜单名称 -->
                                    <TextBlock Margin="10,0,0,0" Text="{Binding Name}" VerticalAlignment="Center" Padding="0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </materialDesign:DrawerHost.LeftDrawerContent>

            <DockPanel>
                <materialDesign:ColorZone x:Name="ColorZoneTilteBar"
                                          Padding="12"
                                          materialDesign:ElevationAssist.Elevation="Dp4"
                                          DockPanel.Dock="Top"
                                          Mode="PrimaryMid">
                    <DockPanel LastChildFill="False">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                            <ToggleButton x:Name="MenuToggleButton"
                                          AutomationProperties.Name="HamburgerToggleButton"
                                          IsChecked="False"
                                          Style="{StaticResource MaterialDesignHamburgerToggleButton}" />

                            <Button Margin="24,0,0,0"
                                    materialDesign:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={x:Static materialDesignConverters:BrushRoundConverter.Instance}}"
                                    Command="{Binding GoBackCommand}"
                                    Content="{materialDesign:PackIcon Kind=ArrowLeft,Size=24}"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    ToolTip="Previous Item" Cursor="Hand" />

                            <Button Margin="16,0,0,0"
                                    materialDesign:RippleAssist.Feedback="{Binding RelativeSource={RelativeSource Self}, Path=Foreground, Converter={x:Static materialDesignConverters:BrushRoundConverter.Instance}}"
                                    Command="{Binding GoForwardCommand}"
                                    Content="{materialDesign:PackIcon Kind=ArrowRight,Size=24}"
                                    Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}"
                                    Style="{StaticResource MaterialDesignToolButton}"
                                    ToolTip="Next Item" Cursor="Hand" />

                            <!-- 标题 -->
                            <TextBlock Margin="20,0,0,0"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   AutomationProperties.Name="Material Design In XAML Toolkit"
                                   FontSize="22"
                                   Text="记事本" />
                        </StackPanel>


                        <!-- 右边的头像、缩小、放大、关闭按钮 -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <!-- 头像 -->
                            <!-- 嵌入资源使用以下路径    /项目名;component/路径 -->
                            <Image Source="/MemoDesktop;component/Assets/Images/新之助.jpg" Width="35" Height="35">
                                <Image.Clip>
                                    <!-- 使用EllipseGeometry进行圆形裁剪 -->
                                    <EllipseGeometry Center="17.5,17.5" RadiusX="17.5" RadiusY="17.5"/>
                                </Image.Clip>
                            </Image>
                            <!-- 缩小按钮 -->
                            <Button x:Name="ButtonWindowMin" Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <materialDesign:PackIcon Kind="WindowMinimize" />
                            </Button>
                            <!-- 放大按钮 -->
                            <Button x:Name="ButtonWindowMax" Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <materialDesign:PackIcon Kind="WindowMaximize" />
                            </Button>
                            <!-- 关闭按钮 -->
                            <Button x:Name="ButtonWindowClose" Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <materialDesign:PackIcon Kind="WindowClose" />
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </materialDesign:ColorZone>
                <!--
                MaterialDesign的 DrawerHost 控件：
                它是一个内容控件 (ContentControl)，只能包含一个直接子元素
                这个子元素就是它的"主内容区"
                抽屉内容通过 LeftDrawerContent 属性单独设置
                -->
                <!-- 导航区域 -->
                <ContentControl
                    prism:RegionManager.RegionName="{x:Static constants:RegionNames.MainViewRegionName}"
                    VerticalContentAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"/>
            </DockPanel>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</Window>
