<UserControl x:Class="MemoDesktop.Views.Components.UpdateLoadingAnimation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MemoDesktop.Views.Components"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border
            Width="200"
            Height="120"
            BorderThickness="1"
            CornerRadius="20"
            Padding="10">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <ProgressBar
                    Width="40"
                    Height="40"
                    IsIndeterminate="True"
                    Margin="0,15,0,0"
                    Style="{StaticResource MaterialDesignCircularProgressBar}" />
                <TextBlock
                    x:Name="LoadingHint"
                    Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Margin="0,10,0,0" 
                    FontSize="16"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
