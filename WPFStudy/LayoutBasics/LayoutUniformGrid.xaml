<Window x:Class="WPFStudy.LayoutBasics.LayoutUniformGrid"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.LayoutBasics"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="LayoutUniformGrid" Height="450" Width="800">
    <Grid>
        <!-- UniformGrid是一个非常有用的布局容器，它将所有单元格设置为统一尺寸，并自动根据子元素数量创建行列。这对于创建棋盘、仪表盘、图片库等需要均匀排列元素的界面非常方便 -->
        <!-- Rows: 设置行数。设置为0表示自动计算行数 - 默认值0 -->
        <!-- Columns: 设置列数。设置为0表示自动计算列数 - 默认值0 -->
        <!-- FirstRow: 指定起始行索引 - 默认值0 -->
        <!-- FirstColumn: 指定起始列索引 - 默认值0 -->

        <UniformGrid>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
            <ui:Button Background="Green" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"></ui:Button>
        </UniformGrid>
    </Grid>
</Window>
