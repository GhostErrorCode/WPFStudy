<Window x:Class="WPFStudy.LayoutBasics.LayoutExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.LayoutBasics"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="LayoutExample" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部栏 -->
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        
        <!-- 顶部栏Border -->
        <Border Background="#7671D8"></Border>
        
        <!-- 所有的布局容器都是可以嵌套的 -->
        <!-- 此Grid用上级Grid剩下的部分继续分割 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 侧边导航栏 -->
                <ColumnDefinition Width="200"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <!-- 侧边导航栏Border -->
            <Border Background="Blue"></Border>
            
            <!-- 继续使用上级Grid剩余的部分 -->
            <!-- 内容区域 分成三行五列-->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.6*"></RowDefinition>
                    <RowDefinition Height="1.2*"></RowDefinition>
                    <RowDefinition Height="0.8*"></RowDefinition>
                </Grid.RowDefinitions>
                
                <!-- 第一行的5个内容块 -->
                <Border Grid.Row="0" Grid.Column="0" Background="#7671D8" Margin="7"></Border>
                <Border Grid.Row="0" Grid.Column="1" Background="#4C9ECD" Margin="7"></Border>
                <Border Grid.Row="0" Grid.Column="2" Background="#D970CF" Margin="7"></Border>
                <Border Grid.Row="0" Grid.Column="3" Background="#5AC4B6" Margin="7"></Border>
                <Border Grid.Row="0" Grid.Column="4" Background="#D9707F" Margin="7"></Border>
                <!-- 第二行的2个内容块 -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Background="#D9707F" Margin="7"></Border>
                <Border Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Background="#D9707F" Margin="7"></Border>
                <!-- 第三行的2个内容块 -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="#D9707F" Margin="7"></Border>
                <Border Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2" Background="#D9707F" Margin="7"></Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
