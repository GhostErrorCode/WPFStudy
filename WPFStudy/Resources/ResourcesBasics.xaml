<Window x:Class="WPFStudy.Resources.ResourcesBasics"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Resources"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="ResourcesBasics" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Button Margin="10" Content="Update" Foreground="Black" BorderBrush="Black" BorderThickness="3" HorizontalAlignment="Stretch" Click="Button_Click"/>
            <Button Margin="10" Content="静态资源引用 不会变" Foreground="Black" BorderBrush="{StaticResource SolidColor}" BorderThickness="3" HorizontalAlignment="Stretch"/>
            <Button Margin="10" Content="动态资源引用 会变" Foreground="Black" BorderBrush="{DynamicResource SolidColor}" BorderThickness="3" HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
