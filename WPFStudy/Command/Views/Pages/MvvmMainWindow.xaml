<Window x:Class="WPFStudy.Command.Views.Pages.MvvmMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Command.Views.Pages"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="MvvmMainWindow" Height="450" Width="800" Cursor="">
    <Grid>
        <!-- 垂直容器 -->
        <StackPanel Orientation="Vertical">
            <!-- UpdateSourceTrigger说明：示例1：PropertyChanged - 文本每次改变时立即更新 -->
            <!-- 示例2：LostFocus - 失去焦点时更新（默认行为） -->
            <!-- 示例3：Explicit - 手动控制更新 -->
            <ui:TextBox PlaceholderText="Type something..." Margin="10" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Cursor="IBeam"></ui:TextBox>
            <ui:Button Command="{Binding MvvmCommandStudy}" Appearance="Primary" Content="MvvmCommandStudy" Icon="{ui:SymbolIcon KeyCommand24}" HorizontalAlignment="Stretch" Height="50" Margin="10" Cursor=""></ui:Button>
        </StackPanel>
    </Grid>
</Window>
