<Window x:Class="WPFStudy.Bind.BindingElement"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Bind"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="BindingElement" Height="450" Width="800">
    <Grid>
        <!-- 控件之间的绑定 -->
        <!--
        ElementName	{Binding Path=X, ElementName=Y}	同一XAML内的控件绑定
        DataContext	{Binding Property}	ViewModel数据绑定
        RelativeSource	{Binding RelativeSource={...}}	模板内绑定、查找父元素
        -->
        <StackPanel Orientation="Vertical" Cursor="">
            <Slider x:Name="slider" Margin="5"></Slider>
            <ui:TextBox Text="{Binding ElementName=slider, Path=Value, Mode=OneTime}" Margin="5" PlaceholderText="仅初始化时绑定一次"></ui:TextBox>
            <ui:TextBox Text="{Binding ElementName=slider, Path=Value, Mode=OneWay}" Margin="5" PlaceholderText="数据源变化 → 更新目标"></ui:TextBox>
            <ui:TextBox Text="{Binding ElementName=slider, Path=Value, Mode=TwoWay}" Margin="5" PlaceholderText="数据源 ⇄ 目标双向同步" Cursor="IBeam"></ui:TextBox>
            <ui:TextBox Text="{Binding ElementName=slider, Path=Value, Mode=OneWayToSource}" Margin="5" PlaceholderText="目标变化 → 更新数据源"></ui:TextBox>
        </StackPanel>
        
        <!--
        绑定模式:
        1.OneWay - 数据源变化 → 更新目标
        2.TwoWay - 数据源 ⇄ 目标双向同步
        3.OneWayToSource - 目标变化 → 更新数据源
        4.OneTime - 仅初始化时绑定一次
        -->
    </Grid>
</Window>
