<Window x:Class="WPFStudy.StyleBasics.StyleBasic"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.StyleBasics"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="StyleBasic" Height="450" Width="800">

    <!-- <Window.Resources>...</Window.Resources> 是WPF中非常重要的资源定义区域，用于在窗口级别定义和存储可重用的对象 -->
    <Window.Resources>
        <!-- 资源容器:
              作用域：定义的资源在当前窗口及其所有子元素中可用
              生命周期：与窗口的生命周期相同，窗口关闭时资源被释放
              查找顺序：WPF按以下顺序查找资源：
                        元素自身的Resources
                        父元素的Resources（向上递归）
                        Window.Resources
                        Application.Resources
                        系统资源
        -->
        <!-- 
        可定义的资源类型有：
        1. 样式（Styles）
        2. 画笔（Brushes）
        3. 模板（Templates）
        4. 数据模板（DataTemplates）
        5. 转换器（Converters）
        6. 集合和对象
        -->
        
        <!-- <Style TargetType="ui:Button"> 这样写会改变所有ui:Button的样式 -->
        <Style TargetType="Button">
            <!-- <Setter Property="属性名称" Value="属性值"/>是WPF样式系统中用于设置控件属性的基本单元 -->
            <!-- 
            1. Property（属性）
                必须是依赖属性：只能设置目标控件的依赖属性
                使用字符串格式：直接写属性名，不需要绑定语法
                目标类型匹配：属性必须在样式目标类型中存在
            2. Value（值）
                多种赋值方式：
                    直接值：Value="20"
                    静态资源：Value="{StaticResource MyColor}"
                    动态资源：Value="{DynamicResource MyBrush}"
                    绑定表达式：Value="{Binding Path=TextLength}"
                    标记扩展：Value="{x:Static SystemColors.ActiveCaptionBrush}"
            -->
            <!-- 设置Style字体大小 -->
            <Setter Property="FontSize" Value="20"></Setter>
            <!-- 设置Style前景颜色 -->
            <Setter Property="Foreground" Value="Blue"></Setter>
            <!-- 设置Style背景颜色 -->
            <Setter Property="Background" Value="Black"></Setter>
            <!-- 设置Style显示内容 -->
            <Setter Property="Content" Value="Button1"></Setter>
        </Style>
        
        
        <!-- 这样写可以让控件自行引用此Style -->
        <Style x:Key="uiButtonStyle" TargetType="ui:Button">
            <Setter Property="FontSize" Value="25"></Setter>
            <Setter Property="Foreground" Value="Green"></Setter>
            <Setter Property="Background" Value="CadetBlue"></Setter>
            <Setter Property="Content" Value="Button2"></Setter>
        </Style>

        <!-- BasedOn继承其他Style或重写 -->
        <Style x:Key="uiButton" TargetType="ui:Button" BasedOn="{StaticResource uiButtonStyle}">
            <Setter Property="Content" Value="ButtonBasedOn"></Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <!-- 依旧两行两列 -->
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <!-- Style: 组织和重用一组属性值的工具，应用于多个元素。Style 是一组Setter的集合 -->
        <!-- Resources: 通常在XAML文件的 Resources 部分声明为资源，遵循资源作用域规则。例：<Window.Resources>...</Window.Resources> -->
        <!-- TargetType: 指定样式应用于的控件类型（如Button, TextBlock）。例：TargetType="{x:Type Button}" -->
        <!-- Setter: 设置控件的单个依赖属性值，由Property和Value组成。例：<Setter Property="FontSize" Value="14"/> -->
        <!-- x:Key & {StaticResource}: 显式引用：为样式定义键名(x:Key)，使用时通过键名引用。例：Style="{StaticResource MyStyle}" -->
        <!-- BasedOn: 新样式可以基于现有样式继承和扩展，重写属性以新值为准。例：BasedOn="{StaticResource {x:Type TextBlock}}" -->
        <!-- 触发器 (Triggers): 在特定条件满足时自动改变控件外观 -->
        <!-- Trigger (属性触发器): 监视依赖属性值变化。例：鼠标悬停(IsMouseOver)时改变背景色 -->
        <!-- MultiTrigger (多条件触发器): 多个条件同时满足时触发。例：元素获取焦点且鼠标悬停时触发 -->
        <!-- EventTrigger (事件触发器): 路由事件发生时触发，通常用于启动动画 -->
        
        <!-- 第一行第一列 -->
        <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center">
            <Button></Button>
            <Button></Button>
            <Button></Button>
            <Button></Button>
            <Button></Button>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left">
            <ui:Button Style="{ StaticResource uiButtonStyle }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButtonStyle }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButtonStyle }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButtonStyle }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButtonStyle }"></ui:Button>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right">
            <!-- 控件中定义的属性优先级是最高的 -->
            <ui:Button Content="优先级最高" Style="{ StaticResource uiButton }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButton }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButton }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButton }"></ui:Button>
            <ui:Button Style="{ StaticResource uiButton }"></ui:Button>
        </StackPanel>
    </Grid>
</Window>
