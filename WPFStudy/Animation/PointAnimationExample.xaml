<Window x:Class="WPFStudy.Animation.PointAnimationExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Animation"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="PointAnimationExample" Height="450" Width="800">
    <Grid>
        <!-- 使用画布布局，可以精确控制元素位置 -->
        <Canvas>
            <!-- 要应用点动画的椭圆（作为移动的点） -->
            <Ellipse x:Name="MovingPointEllipse" 
                     Width="30" 
                     Height="30" 
                     Fill="Green">
                <!-- 设置椭圆的渲染变换 -->
                <Ellipse.RenderTransform>
                    <!-- 使用平移变换来控制椭圆位置 -->
                    <TranslateTransform x:Name="EllipseTranslateTransform" 
                                        X="0" 
                                        Y="0"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- 触发点动画的按钮 -->
            <ui:Button x:Name="PointAnimationButton" 
                Content="执行点动画" 
                Click="PointAnimationButton_Click"
                Width="120" 
                Height="30" 
                Canvas.Left="40" 
                Canvas.Top="40"
                Icon="{ui:SymbolIcon ConvertRange20}"
                Background="#3B82F6"
                Foreground="White"/>

        </Canvas>
    </Grid>
</Window>
