<Window x:Class="WPFStudy.Animation.DoubleAnimationUsingKeyFramesExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Animation"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="DoubleAnimationUsingKeyFramesExample" Height="450" Width="800">
    <Grid>
        <!-- 使用画布布局，可以精确控制元素位置 -->
        <Canvas>
            <!-- 要应用弹跳动画的矩形 -->
            <Rectangle x:Name="BouncingRectangle" 
                   Width="60" 
                   Height="60" 
                   Fill="Orange" 
                   Canvas.Left="50" 
                   Canvas.Top="0"/>

            <!-- 触发弹跳动画的按钮 -->
            <ui:Button x:Name="BounceAnimationButton" 
                Content="执行弹跳动画" 
                Click="BounceAnimationButton_Click"
                Width="150" 
                Height="30" 
                Canvas.Left="10" 
                Canvas.Top="200"
                Icon="{ui:SymbolIcon ConvertRange20}"
                Background="#3B82F6"
                Foreground="White"/>
        </Canvas>
    </Grid>
</Window>
