<Window x:Class="WPFStudy.Animation.DoubleAnimationExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Animation"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="DoubleAnimationExample" Height="450" Width="800">
    <Grid>
        <!-- 垂直排列的子元素容器 -->
        <StackPanel Orientation="Vertical" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center">

            <!-- 要应用淡入动画的文本块 -->
            <TextBlock x:Name="FadeInTextBlock" 
                       Text="这是一个淡入动画示例文本" 
                       FontSize="20" 
                       Opacity="0"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       Margin="0,0,0,20"/>
            <!-- 初始透明度为0（完全透明） -->
            <!-- Opacity="0" -->

            <!-- 触发淡入动画的按钮 -->
            <ui:Button x:Name="FadeInButton" 
                    Content="执行淡入动画" 
                    Click="FadeInButton_Click"
                    Width="150" 
                    Height="30" 
                    HorizontalAlignment="Center"
                    Icon="{ui:SymbolIcon KeyCommand24}"/>
                    
        </StackPanel>
    </Grid>
</Window>
