<Window x:Class="WPFStudy.Animation.AnimationBasics"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Animation"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="AnimationBasics" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical">
            <ui:Button x:Name="btu"
                       Appearance="Primary"
                       Content="AnimationStudy"
                       Icon="{ui:SymbolIcon KeyCommand24}"
                       Height="50"
                       Width="700"
                       Margin="10"
                       Click="btu_Click"/>
        </StackPanel>
    </Grid>
</Window>
