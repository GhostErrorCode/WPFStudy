<Window x:Class="WPFStudy.Animation.EasingFunctionExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFStudy.Animation"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="EasingFunctionExample" Height="450" Width="800">

    <Window.Resources>
        <!-- 定义包含缓动函数的故事板 -->
        <Storyboard x:Key="BounceAnimation">
            <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                From="0,0,0,0" 
                                To="200,0,0,0" 
                                Duration="0:0:2">
                <ThicknessAnimation.EasingFunction>
                    <!-- 直接在XAML中定义弹跳缓动函数 -->
                    <BounceEase EasingMode="EaseOut" 
                                 Bounces="2"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- 垂直排列控件 -->
        <StackPanel VerticalAlignment="Center" 
                    HorizontalAlignment="Center">

            <!-- 要移动的矩形 -->
            <Rectangle x:Name="MovingRectangle" 
                       Width="50" 
                       Height="50" 
                       Fill="Blue" 
                       Margin="0,0,0,20"/>

            <!-- 使用弹跳缓动函数的按钮 -->
            <Button Content="弹跳移动" 
                    Click="BounceMoveButton_Click" 
                    Width="100" 
                    Height="30"/>
        </StackPanel>
    </Grid>
</Window>
